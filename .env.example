# Copy to `.env.local` (local dev) or `.env.production` (build) in the REPO ROOT.
# Vite does not load `supabase/env.production` — variables must live in root `.env*` files.
# Vite bakes these into the JS at build time—GitHub Pages needs GitHub Actions secrets (see .github/workflows/build.yml).
# Harvest → Supabase Edge Function (anon key is public by design in Supabase).
VITE_HARVEST_INTEREST_WEBHOOK_URL=https://pvtrqnvacjdquktdcqfh.supabase.co/functions/v1/harvest-interest
# Project API keys → anon → public (JWT eyJ… or sb_publishable_…). Never sb_secret_* or service_role.
VITE_SUPABASE_ANON_KEY=paste_anon_public_key_from_supabase_settings_api
