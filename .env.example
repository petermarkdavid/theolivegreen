# Copy to `.env.production` in this repo before `npm run build` or `npm run deploy`.
# Vite bakes these into the JS at build time—GitHub Pages will NOT have them unless the build ran with this file present.
# Harvest + newsletter → Supabase Edge Functions (anon key is public by design in Supabase).
VITE_HARVEST_INTEREST_WEBHOOK_URL=https://pvtrqnvacjdquktdcqfh.supabase.co/functions/v1/harvest-interest
VITE_NEWSLETTER_WEBHOOK_URL=https://pvtrqnvacjdquktdcqfh.supabase.co/functions/v1/newsletter-signup
VITE_SUPABASE_ANON_KEY=paste_anon_key_from_supabase_dashboard_settings_api
